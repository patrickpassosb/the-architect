{
  "name": "the-architect",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm run dev:all",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:api": "npm run dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "lint": "npm run --workspaces lint",
    "test": "npm run --workspaces test",
    "typecheck": "npm run --workspaces typecheck",
    "redis:up": "docker compose -f infra/docker-compose.yml up -d redis",
    "redis:down": "docker compose -f infra/docker-compose.yml down",
    "test:integration": "node tests/integration.mjs",
    "workflow:docker-loop": "bash scripts/agent-docker-loop.sh",
    "test:smoke": "REQUIRE_PROVIDER_SUCCESS=1 node tests/integration.mjs",
    "test:smoke:loop": "bash scripts/smoke-loop.sh"
  }
}
