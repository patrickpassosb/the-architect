# --- API Configuration ---
# Fastify server settings
PORT=4000
HOST=0.0.0.0

# --- Infrastructure ---
# Full connection URL for local or managed Redis (BullMQ backend)
REDIS_URL=redis://127.0.0.1:6379

# Local SQLite database path (resolved relative to repository root)
DATABASE_URL=./data/the-architect.sqlite

# --- AI Integration ---
# Required: Your Mistral API key from https://console.mistral.ai
MISTRAL_API_KEY=

# Optional: The Mistral model to use for reasoning (default is mistral-large-latest)
MISTRAL_MODEL=mistral-large-latest

# Optional: Custom API URL for Mistral-compatible services
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

# --- Worker Configuration ---
# Number of concurrent jobs the worker should process
WORKER_CONCURRENCY=4

# Health check port for the worker (Cloud Run readiness)
WORKER_PORT=4100

# --- Frontend Configuration ---
# Required for client-side API access in Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
